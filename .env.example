# REQUIRED (build-time). Comma-separated domains allowed to embed and drive the engine.
# Entries: bare hostname, *.wildcard, or localhost/127.0.0.1 (http allowed, any port).
# Inlined into the client bundle and the frame-ancestors CSP at `next build`.
NEXT_PUBLIC_ALLOWED_DOMAINS=machcomputing.com,*.machcomputing.com,localhost
